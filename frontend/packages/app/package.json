    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-table": "^8.20.5",
    "frappe-react-sdk": "^1.13.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.539.0",
    "react-redux": "^9.1.2",
